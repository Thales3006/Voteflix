<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="1000.0" stylesheets="@style.css"
    xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.thales.client.controller.LoginController">
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="connection-bar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="detail-label" text="IPv4" />
            <TextField fx:id="IPField" prefWidth="140.0" promptText="000.000.000.000" text="localhost" />
            <Label styleClass="detail-label" text="Port" />
            <TextField fx:id="portField" prefWidth="68.0" promptText="00000" text="20737" />
            <Button fx:id="connectButton" mnemonicParsing="false" onAction="#HandleConnectButton" prefWidth="100.0" text="Connect" />
            <Button fx:id="disconnectButton" disable="true" mnemonicParsing="false" onAction="#HandleDisconnectButton" prefWidth="110.0" text="Disconnect" />
         </children>
         <padding>
            <Insets bottom="10.0" left="16.0" right="16.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
   <center>
      <StackPane BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="20.0">
               <children>
                  <Label styleClass="page-title" text="VOTEFLIX" />
                  <Label styleClass="detail-label" text="Movie Reviews" />
                  <VBox styleClass="form-card" spacing="18.0" maxWidth="320.0">
                     <children>
                        <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Sign In" />
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="detail-label" text="Username" />
                              <TextField fx:id="usernameField" prefWidth="260.0" promptText="Username" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="detail-label" text="Password" />
                              <PasswordField fx:id="passwordField" prefWidth="260.0" promptText="Password" />
                           </children>
                        </VBox>
                        <HBox alignment="CENTER" spacing="12.0">
                           <children>
                              <Button fx:id="loginButton" mnemonicParsing="false" onAction="#HandleLoginButton" prefWidth="112.0" text="Sign In" />
                              <Button fx:id="registerButton" mnemonicParsing="false" onAction="#HandleRegisterButton" prefWidth="112.0" text="Register" />
                           </children>
                        </HBox>
                        <Label fx:id="statusLabel" styleClass="status-label" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>
