{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateUserRequest",
  "type": "object",
  "properties": {
    "operation": { "type": "string", "const": "CREATE_USER" },
    "user": {
      "type": "object",
      "properties": {
        "username": { "$ref": "../components/base_string.json" },
        "password": { "$ref": "../components/base_string.json" }
      },
      "required": ["username", "password"],
      "additionalProperties": false
    }
  },
  "required": ["operation", "user"],
  "additionalProperties": false
}
