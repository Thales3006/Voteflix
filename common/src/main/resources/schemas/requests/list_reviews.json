{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ListReviewsRequest",
  "type": "object",
  "properties": {
    "operation": { "type": "string", "const": "LIST_REVIEWS" },
    "token":     { "type": "string" },
    "filter": {
      "type": "object",
      "properties": {
        "movie_id": { "type": "integer" },
        "user_id":  { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "required": ["operation", "token"],
  "additionalProperties": false
}
