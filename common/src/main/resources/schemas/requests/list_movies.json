{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ListMoviesRequest",
  "type": "object",
  "properties": {
    "operation": { "type": "string", "const": "LIST_MOVIES" },
    "token":     { "type": "string" },
    "filter": {
      "type": "object",
      "properties": {
        "genre": { "type": "string" },
        "year":  { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "required": ["operation", "token"],
  "additionalProperties": false
}
