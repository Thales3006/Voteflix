{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AdminUpdateUserRequest",
  "type": "object",
  "properties": {
    "operation": { "type": "string", "const": "ADMIN_UPDATE_USER" },
    "token": { "type": "string" },
    "id":    { "type": "integer" },
    "user": {
      "type": "object",
      "properties": {
        "password": { "$ref": "../components/base_string.json" }
      },
      "required": ["password"],
      "additionalProperties": false
    }
  },
  "required": ["operation", "token", "id", "user"],
  "additionalProperties": false
}
