{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserListResponse",
  "type": "object",
  "properties": {
    "status":  { "type": "string", "const": "200" },
    "message": { "type": "string" },
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id":       { "type": "integer" },
          "username": { "$ref": "../components/base_string.json" }
        },
        "required": ["id", "username"],
        "additionalProperties": false
      }
    }
  },
  "required": ["status", "users"],
  "additionalProperties": false
}
