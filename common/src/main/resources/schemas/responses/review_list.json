{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewListResponse",
  "type": "object",
  "properties": {
    "status":  { "type": "string", "pattern": "^2[0-9]{2}$" },
    "message": { "type": "string" },
    "reviews": {
      "type": "array",
      "items": { "$ref": "../components/review_response.json" }
    }
  },
  "required": ["status", "reviews"],
  "additionalProperties": false
}
