{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ErrorResponse",
  "type": "object",
  "properties": {
    "status":  { "type": "string", "pattern": "^(400|401|403|404|409|422|500)$" },
    "message": { "type": "string" }
  },
  "required": ["status", "message"],
  "additionalProperties": false
}
