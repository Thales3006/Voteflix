{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LoginResponse",
  "type": "object",
  "properties": {
    "status":  { "type": "string", "pattern": "^2[0-9]{2}$" },
    "message": { "type": "string" },
    "token":   { "type": "string" },
    "id":      { "type": "integer" }
  },
  "required": ["status", "token", "id"],
  "additionalProperties": false
}
