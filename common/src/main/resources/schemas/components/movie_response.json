{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MovieResponse",
  "type": "object",
  "properties": {
    "id":           { "type": "integer" },
    "title":        { "type": "string" },
    "director":     { "type": "string" },
    "year":         { "type": "integer" },
    "genre":        { "type": "array", "items": { "type": "string" } },
    "synopsis":     { "type": "string" },
    "rating":       { "type": "number" },
    "rating_count": { "type": "integer" }
  },
  "required": ["id", "title", "director", "year", "genre", "synopsis", "rating", "rating_count"],
  "additionalProperties": false
}
